# MongoDB connection string (e.g., mongodb://localhost:27017)
MONGODB_URL=mongodb://localhost:27017

# Name of the MongoDB database to use
MONGODB_DB_NAME=used_laptops_db

# Secret key for signing JWT tokens (use a strong, random string)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this

# Algorithm used for JWT signing (default: HS256)
JWT_ALGORITHM=HS256

# Access token expiration time in minutes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Server
HOST=127.0.0.1
PORT=8007

# Comma-separated list of allowed CORS origins
# FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173

# Frontend API URL (Vite exposes VITE_* vars to client code)
VITE_API_URL=http://127.0.0.1:8007

# WhatsApp Business API (for notifications)
NOTIFICATION_PROVIDER=console
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=notification_template
